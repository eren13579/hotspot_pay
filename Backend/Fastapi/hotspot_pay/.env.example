APP_NAME=HotspotPay FastAPI Microservice
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8443
DATABASE_URL=sqlite+aiosqlite:///./hotspotpay.db
REDIS_URL=redis://localhost:6379/0
LONG_POLL_TIMEOUT=20
LONG_POLL_INTERVAL=0.5
API_KEY=your-strong-api-key-here
TICKET_CODE_LENGTH=3
DEFAULT_HOTSPOT_PROFILE=default
JAVA_CALLBACK_URL=http://localhost:8080/internal/router-callback
JAVA_CALLBACK_TIMEOUT=5.0
