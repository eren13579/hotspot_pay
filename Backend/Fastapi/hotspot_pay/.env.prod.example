# ═══════════════════════════════════════════════════════
# Variables d'environnement PRODUCTION — HotspotPay FastAPI
# NE PAS committer ce fichier avec les vraies valeurs !
# Copier vers .env et remplir les valeurs réelles.
# ═══════════════════════════════════════════════════════

APP_NAME=HotspotPay FastAPI Microservice
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8443

DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_USER=hotspotpay
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE
DB_NAME=hotspot_fastapi

REDIS_URL=redis://your-redis-host:6379/0
LONG_POLL_TIMEOUT=20
LONG_POLL_INTERVAL=0.5

# Générer: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=YOUR_FASTAPI_API_KEY_HERE

TICKET_CODE_LENGTH=3
DEFAULT_HOTSPOT_PROFILE=default

# URL du backend Java (endpoint callback)
JAVA_CALLBACK_URL=https://your-java-api.internal/api/V1/internal/router-callback
JAVA_CALLBACK_TIMEOUT=5.0

# Générer: python -c "import secrets; print(secrets.token_hex(32))"
JAVA_CALLBACK_SECRET=YOUR_CALLBACK_SECRET_HERE

# CORS: liste d'origines autorisées (pas de wildcard en prod)
CORS_ALLOWED_ORIGINS=https://your-frontend.com,https://admin.your-frontend.com
