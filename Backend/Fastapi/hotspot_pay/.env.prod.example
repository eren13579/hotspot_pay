# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION — HotspotPay FastAPI Microservice
# Copier vers .env, remplir les valeurs réelles, NE PAS committer.
# ══════════════════════════════════════════════════════════════════════════════

APP_NAME=HotspotPay FastAPI Microservice
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8443

# ── Base de données PostgreSQL ──────────────────────────────────────────────
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_USER=hotspotpay
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE
DB_NAME=hotspot_fastapi

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://your-redis-host:6379/0

# ── Long Polling routeurs ───────────────────────────────────────────────────
LONG_POLL_TIMEOUT=20
LONG_POLL_INTERVAL=0.5

# ── API Key (générer: python -c "import secrets; print(secrets.token_urlsafe(32))") ──
API_KEY=YOUR_FASTAPI_API_KEY_HERE

# ── Tickets ─────────────────────────────────────────────────────────────────
TICKET_CODE_LENGTH=3
DEFAULT_HOTSPOT_PROFILE=default

# ── URL publique du service (pour les scripts routeur) ─────────────────────
PUBLIC_URL=https://api.votre-domaine.com:8443

# ── Backend Java (callback) ─────────────────────────────────────────────────
JAVA_CALLBACK_URL=https://votre-domaine.com/api/V1/internal/router-callback
JAVA_CALLBACK_TIMEOUT=5.0
# Générer: python -c "import secrets; print(secrets.token_hex(32))"
JAVA_CALLBACK_SECRET=YOUR_CALLBACK_SECRET_HERE

# ── CORS (pas de wildcard en prod — liste d'origines séparée par des virgules) ──
CORS_ALLOWED_ORIGINS=https://votre-frontend.com,https://admin.votre-frontend.com
