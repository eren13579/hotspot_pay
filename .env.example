# ============================================================
# HotspotPay — Variables d'environnement (Docker Compose unifié)
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Bases de données ─────────────────────────────────────
POSTGRES_PASSWORD=Teda@2003
REDIS_PASSWORD=

# ── JWT (minimum 32 caractères !) ────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production-32chars

# ── Jasypt (chiffrement mots de passe MikroTik) ──────────
JASYPT_KEY=change-me-jasypt-key

# ── Communication inter-service ──────────────────────────
FASTAPI_API_KEY=change-me-api-key
FASTAPI_CALLBACK_SECRET=change-me-callback-secret

# ── URL publique (obligatoire pour les webhooks en prod) ─
BASE_URL=http://localhost:8080
